# Environment variables for Adaptive Learning Platform
# OpenAI API 설정
OPENAI_API_KEY=your_openai_api_key_here

# 데이터베이스 설정 (향후 확장용)
DATABASE_URL=sqlite:///exam_system.db

# 로깅 설정
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 애플리케이션 설정
DEBUG=False
SECRET_KEY=your-secret-key-here

# 보안 설정
TEACHER_PASSWORD=teacher2025