# Environment variables for Adaptive Learning Platform
# AI API 설정 (OpenAI 또는 Google Gemini 중 하나 사용)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# AI 백엔드 선택: "openai" 또는 "gemini" (기본값: gemini)
AI_BACKEND=gemini

# 데이터베이스 설정 (향후 확장용)
DATABASE_URL=sqlite:///exam_system.db

# 로깅 설정
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 애플리케이션 설정
DEBUG=False
SECRET_KEY=your-secret-key-here

# 보안 설정
TEACHER_PASSWORD=teacher2025

# Redis 캐시 (docker-compose up -d 실행 후 사용)
REDIS_URL=redis://localhost:6379/0